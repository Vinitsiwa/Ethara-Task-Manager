# Backend
DATABASE_URL=sqlite:///./vinit_taskhub.db
# PostgreSQL example (Railway):
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:PORT/DATABASE

ENVIRONMENT=development

# Comma-separated browser origins. Leave empty in production when UI and API share one host.
CORS_ORIGINS=

SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

PORT=8000

# Frontend build-time (optional; leave empty for same-origin `/api`)
VITE_API_URL=
